  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Multi-Region Error Rate Comparison (5xx)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-cloud"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-cloud"
          },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[5m])) by (region) or sum(rate(http_server_duration_count{http_status_code=~\"5..\"}[5m])) by (region)",
          "legendFormat": "{{region}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "reqps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "PostgreSQL Replication Lag",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-cloud"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-cloud"
          },
          "editorMode": "code",
          "expr": "pg_replication_lag_seconds or pg_stat_replication_replay_lag or (pg_replication_lag{role=\"replica\"})",
          "legendFormat": "Replication Lag (s)",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line"
          },
          "unit": "s"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "title": "Redis Sentinel Master Status",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-cloud"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-cloud"
          },
          "editorMode": "code",
          "expr": "redis_sentinel_masters or redis_sentinel_tilt or (redis_connected_slaves)",
          "legendFormat": "{{instance}} state",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "title": "Cloudflare Traffic by Region",
      "type": "timeseries",
      "datasource": {
        "type": "cloudflare-api",
        "uid": "cloudflare-cloud"
      },
      "targets": [
        {
          "datasource": {
            "type": "cloudflare-api",
            "uid": "cloudflare-cloud"
          },
          "target": "requests_by_region",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bar",
            "fillOpacity": 80
          },
          "unit": "decrequests"
        }
      }
    }
  ],
