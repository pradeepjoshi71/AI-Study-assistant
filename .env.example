# ==============================================================================
# AI Study Assistant Platform - Unified Environment Variable Templates
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. GLOBAL / SHARED CONFIGURATION
# ------------------------------------------------------------------------------
NODE_ENV=development
PROJECT_NAME="AI Study Assistant"

# ------------------------------------------------------------------------------
# 2. NEXT.JS WEB APP (apps/web)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000
PORT=3000

# ------------------------------------------------------------------------------
# 3. NESTJS BACKEND API (apps/api)
# ------------------------------------------------------------------------------
API_PORT=3001
API_PREFIX=api/v1

# Database Configuration (PostgreSQL)
# Format: postgresql://[user]:[password]@[host]:[port]/[database]?schema=[schema]
DATABASE_URL="postgresql://postgres:postgres_secure_pass@localhost:5432/study_assistant?schema=public"

# Redis Configuration (NestJS cache & rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=""

# ------------------------------------------------------------------------------
# 4. PYTHON FASTAPI AI SERVICE (apps/ai-service)
# ------------------------------------------------------------------------------
AI_PORT=8000
AI_HOST=0.0.0.0

# Redis Configuration for AI Service
AI_REDIS_HOST=localhost
AI_REDIS_PORT=6379
AI_REDIS_PASSWORD=""

# Qdrant Vector DB Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Google Gemini API Credentials
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------------------------
# 5. DOCKER COMPOSE CONFIGURATION (Local overrides for container context)
# ------------------------------------------------------------------------------
# These are the credentials used inside the PostgreSQL and Redis containers
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=study_assistant
