# Dependency directories
node_modules/
jspm_packages/
web_modules/

# Next.js build output
.next/
out/

# NestJS build output
dist/
*.tsbuildinfo

# Python artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Prisma
/apps/api/src/generated/

# Environment variables and secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Docker
.docker

# OS and IDE configuration files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
thumbs.db
db.crypt

# ─── Terraform ───────────────────────────────────────────────
# Local .terraform directory contains provider binaries
.terraform/
.terraform.lock.hcl

# Terraform state files — managed remotely in S3, never commit locally
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan output (can contain secrets in plaintext)
*.tfplan
plan.out

# Terraform variable files with actual values (use .example equivalents)
# Exception: terraform.tfvars.example is safe to commit
terraform.tfvars
!terraform.tfvars.example
envs/*/terraform.tfvars
!envs/*/terraform.tfvars.example

# Terraform crash logs
crash.log
crash.*.log

# Override files (local developer overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ─── Infrastructure secrets ──────────────────────────────────
# Never commit these
*.pem
*.key
*.crt
id_rsa
id_rsa.pub
.aws/credentials
