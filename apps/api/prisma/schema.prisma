// Prisma Schema for AI Study Assistant Platform

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  name             String?
  avatar           String?
  role             UserRole         @default(STUDENT)
  subscriptionPlan SubscriptionPlan @default(FREE)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  documents        Document[]
  conversations    Conversation[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Document {
  id                    String           @id @default(uuid())
  userId                String
  title                 String
  originalName          String
  fileType              String
  mimeType              String
  fileSize              Int
  fileUrl               String
  storageKey            String
  status                DocumentStatus   @default(UPLOADED)
  pageCount             Int
  extractedTextLength   Int?
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingError       String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks                DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id                 String          @id @default(uuid())
  documentId         String
  chunkIndex         Int
  content            String          @db.Text
  tokenCount         Int
  metadata           Json
  embeddingStatus    EmbeddingStatus @default(PENDING)
  embeddingCreatedAt DateTime?
  createdAt          DateTime        @default(now())
  document           Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  title     String
  summary   String?   @db.Text
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  tenantId       String
  role           MessageRole
  content        String       @db.Text
  citations      Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
}

enum EmbeddingStatus {
  PENDING
  COMPLETED
  FAILED
}

model Quiz {
  id             String         @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  difficulty     String
  createdAt      DateTime       @default(now())
  questions      QuizQuestion[]
  attempts       QuizAttempt[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  type          String   // MCQ | TRUE_FALSE | SHORT_ANSWER
  question      String   @db.Text
  options       Json?    // Optional MCQ choices list: string[]
  answer        String   @db.Text
  explanation   String   @db.Text
  chunkIdSource String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model FlashcardDeck {
  id             String      @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  createdAt      DateTime    @default(now())
  flashcards     Flashcard[]

  @@map("flashcard_decks")
}

model Flashcard {
  id            String            @id @default(uuid())
  deckId        String
  front         String            @db.Text
  back          String            @db.Text
  chunkIdSource String
  tags          Json?             // tag words: e.g. ["topic", "difficulty"]
  createdAt     DateTime          @db.Timestamp(3) @default(now())
  deck          FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews       FlashcardReview[]

  @@map("flashcards")
}

model AnalyticsSession {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  duration  Int      // in seconds
  createdAt DateTime @default(now())

  @@map("analytics_sessions")
}

model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String
  tenantId       String
  quizId         String
  score          Float
  correctAnswers Int
  wrongAnswers   Int
  createdAt      DateTime @default(now())
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model FlashcardReview {
  id          String    @id @default(uuid())
  userId      String
  tenantId    String
  flashcardId String
  recallStatus String    // easy | hard | fail
  createdAt   DateTime  @default(now())
  flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@map("flashcard_reviews")
}

model MasteryScore {
  id         String   @id @default(uuid())
  userId     String
  tenantId   String
  topic      String
  documentId String?
  score      Float
  updatedAt  DateTime @updatedAt

  @@map("mastery_scores")
}

model StudyPlan {
  id        String      @id @default(uuid())
  userId    String
  tenantId  String
  weekStart DateTime
  weekEnd   DateTime
  status    String      // ACTIVE | COMPLETED | ARCHIVED
  createdAt DateTime    @default(now())
  tasks     StudyTask[]

  @@map("study_plans")
}

model StudyTask {
  id        String    @id @default(uuid())
  planId    String
  day       Int       // 1 to 7
  type      String    // QUIZ | FLASHCARD | READING | REVISION
  status    String    // PENDING | COMPLETED | MISSED
  metadata  Json      // details (topic, estimatedTime, chunkIdSources)
  createdAt DateTime  @default(now())
  plan      StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("study_tasks")
}

model TutorInsight {
  id            String   @id @default(uuid())
  userId        String
  tenantId      String
  insightText   String   @db.Text
  priorityLevel String   // HIGH | MEDIUM | LOW
  createdAt     DateTime @default(now())

  @@map("tutor_insights")
}

// ─────────────────────────────────────────────
// Phase 2.1.9 — AI Knowledge Graph Engine
// ─────────────────────────────────────────────

model Concept {
  id          String            @id @default(uuid())
  tenantId    String
  name        String            // normalized lowercase, e.g. "photosynthesis"
  displayName String            // original casing, e.g. "Photosynthesis"
  description String?           @db.Text
  confidence  Float             @default(1.0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chunkMaps   ChunkConceptMap[]
  outgoing    ConceptRelation[] @relation("RelationFrom")
  incoming    ConceptRelation[] @relation("RelationTo")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("concepts")
}

model ConceptRelation {
  id            String   @id @default(uuid())
  tenantId      String
  fromConceptId String
  toConceptId   String
  relationType  String   // EXPLAINS | RELATED_TO | PREREQUISITE_OF | PART_OF
  weight        Float    @default(1.0)
  createdAt     DateTime @default(now())
  fromConcept   Concept  @relation("RelationFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept     Concept  @relation("RelationTo",   fields: [toConceptId],   references: [id], onDelete: Cascade)

  @@unique([tenantId, fromConceptId, toConceptId, relationType])
  @@index([tenantId, fromConceptId])
  @@map("concept_relations")
}

model ChunkConceptMap {
  id         String   @id @default(uuid())
  chunkId    String   // logical FK to document_chunks.id
  conceptId  String
  tenantId   String
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now())
  concept    Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([chunkId, conceptId])
  @@index([tenantId, chunkId])
  @@map("chunk_concept_maps")
}

// ─────────────────────────────────────────────
// Phase 2.2 — Production Hardening Layer
// ─────────────────────────────────────────────

model UsageMetric {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  endpoint  String   // e.g. "chat.send", "quiz.generate"
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  latencyMs Int      @default(0)
  cacheHit  Boolean  @default(false)
  model     String?  // e.g. "gemini-1.5-flash"
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("usage_metrics")
}

model RequestLog {
  id            String   @id @default(uuid())
  correlationId String
  tenantId      String?
  userId        String?
  method        String
  path          String
  statusCode    Int
  latencyMs     Int
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([correlationId])
  @@index([tenantId, createdAt])
  @@map("request_logs")
}

model CostTracking {
  id                String   @id @default(uuid())
  tenantId          String
  userId            String
  period            String   // "2024-06" (year-month bucket)
  totalTokens       Int      @default(0)
  estimatedCostUsd  Float    @default(0)
  updatedAt         DateTime @updatedAt

  @@unique([tenantId, userId, period])
  @@index([tenantId, period])
  @@map("cost_tracking")
}

