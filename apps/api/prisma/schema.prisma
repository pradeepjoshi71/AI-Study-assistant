enum ExamType {
  PRACTICE
  MOCK
  TIMED
}

enum ExamStatus {
  DRAFT
  READY
  ARCHIVED
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  EXPIRED
}

