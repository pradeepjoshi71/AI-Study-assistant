// Prisma Schema for AI Study Assistant Platform

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  READY
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  name             String?
  avatar           String?
  role             UserRole         @default(STUDENT)
  subscriptionPlan SubscriptionPlan @default(FREE)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sessions         Session[]
  documents        Document[]
  conversations    Conversation[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Document {
  id                    String           @id @default(uuid())
  userId                String
  title                 String
  originalName          String
  fileType              String
  mimeType              String
  fileSize              Int
  fileUrl               String
  storageKey            String
  status                DocumentStatus   @default(UPLOADED)
  pageCount             Int
  extractedTextLength   Int?
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  processingError       String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chunks                DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id                 String          @id @default(uuid())
  documentId         String
  chunkIndex         Int
  content            String          @db.Text
  tokenCount         Int
  metadata           Json
  embeddingStatus    EmbeddingStatus @default(PENDING)
  embeddingCreatedAt DateTime?
  createdAt          DateTime        @default(now())
  document           Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  title     String
  summary   String?   @db.Text
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  tenantId       String
  role           MessageRole
  content        String       @db.Text
  citations      Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
}

enum EmbeddingStatus {
  PENDING
  COMPLETED
  FAILED
}

model Quiz {
  id             String         @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  difficulty     String
  createdAt      DateTime       @default(now())
  questions      QuizQuestion[]

  @@map("quizzes")
}

model QuizQuestion {
  id            String   @id @default(uuid())
  quizId        String
  type          String   // MCQ | TRUE_FALSE | SHORT_ANSWER
  question      String   @db.Text
  options       Json?    // Optional MCQ choices list: string[]
  answer        String   @db.Text
  explanation   String   @db.Text
  chunkIdSource String
  quiz          Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model FlashcardDeck {
  id             String      @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  createdAt      DateTime    @default(now())
  flashcards     Flashcard[]

  @@map("flashcard_decks")
}

model Flashcard {
  id            String        @id @default(uuid())
  deckId        String
  front         String        @db.Text
  back          String        @db.Text
  chunkIdSource String
  tags          Json?         // tag words: e.g. ["topic", "difficulty"]
  createdAt     DateTime      @db.Timestamp(3) @default(now())
  deck          FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@map("flashcards")
}
