  sha256     String
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("audit_archives")
}

model APIKeyUsage {
  id         String   @id @default(uuid())
  keyId      String
  endpoint   String
  method     String
  statusCode Int
  latencyMs  Int
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())

  // No FK cascade delete — retained for analytics even after key revocation
  apiKey     ApiKey   @relation(fields: [keyId], references: [id])

  @@index([keyId, createdAt])
  @@map("api_key_usages")
}

model WebhookEndpoint {
  id           String        @id @default(uuid())
  orgId        String
  url          String
  secret       String
  events       String[]
  status       WebhookStatus @default(ACTIVE)
  failureCount Int           @default(0)
  createdAt    DateTime      @default(now())

  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id            String               @id @default(uuid())
  endpointId    String
  event         String
  payload       Json
  statusCode    Int?
  attempts      Int                  @default(0)
  lastAttemptAt DateTime?
  status        WebhookDeliveryStatus @default(PENDING)

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, status])
  @@map("webhook_deliveries")
}

model DeveloperApp {
  id          String   @id @default(uuid())
  orgId       String
  name        String
  description String?
  website     String?
  createdAt   DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("developer_apps")
}

// ─── DEVELOPER PLATFORM ENUMS ─────────────────────────────────────────────────

enum WebhookStatus {
  ACTIVE
  FAILED
  DISABLED
}

enum WebhookDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── REFERRAL AND AFFILIATE SYSTEM ────────────────────────────────────────────

enum ReferralStatus {
  CLICKED
  SIGNED_UP
  CONVERTED
  REWARDED
  FRAUD
}

enum ReferralRewardType {
  CREDIT
  CASH
}

enum ReferralRewardStatus {
  PENDING
  HELD
  PAID
  REJECTED
}

model ReferralCode {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())

  @@map("referral_codes")
}

model Referral {
  id                String          @id @default(uuid())
  referrerId        String
  referrer          User            @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId         String?         @unique
  referee           User?           @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
  code              String
  status            ReferralStatus  @default(CLICKED)
  convertedAt       DateTime?
  ip                String?
  deviceFingerprint String?
  createdAt         DateTime        @default(now())
  rewards           ReferralReward[]

  @@map("referrals")
}

model ReferralReward {
  id         String               @id @default(uuid())
  referralId String
  referral   Referral             @relation(fields: [referralId], references: [id], onDelete: Cascade)
  type       ReferralRewardType
  amount     Float
  status     ReferralRewardStatus @default(PENDING)
  paidAt     DateTime?
  holdUntil  DateTime
  createdAt  DateTime             @default(now())

  @@map("referral_rewards")
}

model AffiliateAccount {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeConnectId String?
  balance         Float    @default(0.0)
  totalEarned     Float    @default(0.0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("affiliate_accounts")
}
