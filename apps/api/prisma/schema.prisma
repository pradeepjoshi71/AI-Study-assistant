// Prisma Schema for AI Study Assistant Platform

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum DocumentStatus {
  PENDING     // Metadata saved, not yet in Minio
  PROCESSING  // Worker is chunking / embedding
  READY       // Fully processed and searchable
  FAILED      // Processing failed (see errorMessage)
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model User {
  id                      String             @id @default(uuid())
  email                   String             @unique
  password                String
  name                    String?
  avatar                  String?
  role                    UserRole           @default(STUDENT)
  subscriptionPlan        SubscriptionPlan   @default(FREE)
  isActive                Boolean            @default(true)
  timezone                String             @default("UTC")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  sessions                Session[]
  documents               Document[]
  conversations           Conversation[]
  // Phase 3.0 — enterprise relations
  organizationMemberships OrgMember[]
  // Phase 3.1 — federated identity relations
  identityProviders       IdentityProvider[]

  stripeCustomerId     String?        @unique
  stripeSubscriptionId String?        @unique
  usageRecords         UsageRecord[]
  invoices             Invoice[]
  subscriptions        Subscription[] @relation("UserSubscriptions")
  userProgress         UserProgress[]
  streaks              Streak[]
  userBadges           UserBadge[]
  deviceTokens         DeviceToken[]
  notificationPreferences NotificationPreference[]

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           String
  refreshTokenHash String   @unique
  expiresAt        DateTime
  userAgent        String?
  ipAddress        String?
  lastActiveAt     DateTime @default(now())
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Document {
  id                    String          @id @default(uuid())
  userId                String
  orgId                 String?

  // Human-readable metadata
  title                 String
  originalName          String
  fileType              String

  // Storage
  storageKey            String          // orgs/{orgId}/docs/{docId}/{filename}
  mimeType              String
  sizeBytes             Int             // canonical size field (replaces fileSize)
  fileUrl               String          // public/presigned URL at upload time

  // Processing lifecycle
  status                DocumentStatus  @default(PENDING)
  errorMessage          String?         // populated on FAILED
  chunkCount            Int             @default(0) // updated by worker
  pageCount             Int             @default(0)

  extractedTextLength   Int?
  processingStartedAt   DateTime?
  processingCompletedAt DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  user                  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization          Organization?   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  chunks                DocumentChunk[]

  @@map("documents")
}

model DocumentChunk {
  id                 String          @id @default(uuid())
  documentId         String
  chunkIndex         Int
  content            String          @db.Text
  tokenCount         Int
  metadata           Json
  embeddingStatus    EmbeddingStatus @default(PENDING)
  embeddingCreatedAt DateTime?
  createdAt          DateTime        @default(now())
  document           Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_chunks")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  title     String
  summary   String?   @db.Text
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  tenantId       String
  role           MessageRole
  content        String       @db.Text
  citations      Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([tenantId])
  @@map("messages")
}

enum EmbeddingStatus {
  PENDING
  COMPLETED
  FAILED
}

model Quiz {
  id             String         @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  difficulty     String
  createdAt      DateTime       @default(now())
  questions      QuizQuestion[]
  attempts       QuizAttempt[]

  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("quizzes")
}

model QuizQuestion {
  id            String @id @default(uuid())
  quizId        String
  type          String // MCQ | TRUE_FALSE | SHORT_ANSWER
  question      String @db.Text
  options       Json? // Optional MCQ choices list: string[]
  answer        String @db.Text
  explanation   String @db.Text
  chunkIdSource String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
}

model FlashcardDeck {
  id             String      @id @default(uuid())
  userId         String
  tenantId       String
  conversationId String?
  title          String
  createdAt      DateTime    @default(now())
  flashcards     Flashcard[]

  @@map("flashcard_decks")
}

model Flashcard {
  id            String            @id @default(uuid())
  deckId        String
  front         String            @db.Text
  back          String            @db.Text
  chunkIdSource String
  tags          Json? // tag words: e.g. ["topic", "difficulty"]
  createdAt     DateTime          @default(now()) @db.Timestamp(3)
  deck          FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews       FlashcardReview[]

  @@map("flashcards")
}

model AnalyticsSession {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  duration  Int // in seconds
  createdAt DateTime @default(now())

  @@map("analytics_sessions")
}

model QuizAttempt {
  id             String   @id @default(uuid())
  userId         String
  tenantId       String
  quizId         String
  score          Float
  correctAnswers Int
  wrongAnswers   Int
  createdAt      DateTime @default(now())
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("quiz_attempts")
}

model FlashcardReview {
  id           String    @id @default(uuid())
  userId       String
  tenantId     String
  flashcardId  String
  recallStatus String // easy | hard | fail
  createdAt    DateTime  @default(now())
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@map("flashcard_reviews")
}

model MasteryScore {
  id         String   @id @default(uuid())
  userId     String
  tenantId   String
  topic      String
  documentId String?
  score      Float
  updatedAt  DateTime @updatedAt

  @@map("mastery_scores")
}

model StudyPlan {
  id        String      @id @default(uuid())
  userId    String
  tenantId  String
  weekStart DateTime
  weekEnd   DateTime
  status    String // ACTIVE | COMPLETED | ARCHIVED
  createdAt DateTime    @default(now())
  tasks     StudyTask[]

  @@map("study_plans")
}

model StudyTask {
  id        String    @id @default(uuid())
  planId    String
  day       Int // 1 to 7
  type      String // QUIZ | FLASHCARD | READING | REVISION
  status    String // PENDING | COMPLETED | MISSED
  metadata  Json // details (topic, estimatedTime, chunkIdSources)
  createdAt DateTime  @default(now())
  plan      StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("study_tasks")
}

model TutorInsight {
  id            String   @id @default(uuid())
  userId        String
  tenantId      String
  insightText   String   @db.Text
  priorityLevel String // HIGH | MEDIUM | LOW
  createdAt     DateTime @default(now())

  @@map("tutor_insights")
}

// ─────────────────────────────────────────────
// Phase 2.1.9 — AI Knowledge Graph Engine
// ─────────────────────────────────────────────

model Concept {
  id          String            @id @default(uuid())
  tenantId    String
  name        String // normalized lowercase, e.g. "photosynthesis"
  displayName String // original casing, e.g. "Photosynthesis"
  description String?           @db.Text
  confidence  Float             @default(1.0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  chunkMaps   ChunkConceptMap[]
  outgoing    ConceptRelation[] @relation("RelationFrom")
  incoming    ConceptRelation[] @relation("RelationTo")

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("concepts")
}

model ConceptRelation {
  id            String   @id @default(uuid())
  tenantId      String
  fromConceptId String
  toConceptId   String
  relationType  String // EXPLAINS | RELATED_TO | PREREQUISITE_OF | PART_OF
  weight        Float    @default(1.0)
  createdAt     DateTime @default(now())
  fromConcept   Concept  @relation("RelationFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)
  toConcept     Concept  @relation("RelationTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fromConceptId, toConceptId, relationType])
  @@index([tenantId, fromConceptId])
  @@map("concept_relations")
}

model ChunkConceptMap {
  id         String   @id @default(uuid())
  chunkId    String // logical FK to document_chunks.id
  conceptId  String
  tenantId   String
  confidence Float    @default(1.0)
  createdAt  DateTime @default(now())
  concept    Concept  @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([chunkId, conceptId])
  @@index([tenantId, chunkId])
  @@map("chunk_concept_maps")
}

// ─────────────────────────────────────────────
// Phase 2.2 — Production Hardening Layer
// ─────────────────────────────────────────────

model UsageMetric {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  endpoint  String // e.g. "chat.send", "quiz.generate"
  tokensIn  Int      @default(0)
  tokensOut Int      @default(0)
  latencyMs Int      @default(0)
  cacheHit  Boolean  @default(false)
  model     String? // e.g. "gemini-1.5-flash"
  createdAt DateTime @default(now())

  @@index([tenantId, userId])
  @@index([tenantId, createdAt])
  @@map("usage_metrics")
}

model RequestLog {
  id            String   @id @default(uuid())
  correlationId String
  tenantId      String?
  userId        String?
  method        String
  path          String
  statusCode    Int
  latencyMs     Int
  errorMessage  String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([correlationId])
  @@index([tenantId, createdAt])
  @@map("request_logs")
}

model CostTracking {
  id               String   @id @default(uuid())
  tenantId         String
  userId           String
  period           String // "2024-06" (year-month bucket)
  totalTokens      Int      @default(0)
  estimatedCostUsd Float    @default(0)
  updatedAt        DateTime @updatedAt

  @@unique([tenantId, userId, period])
  @@index([tenantId, period])
  @@map("cost_tracking")
}

// ─────────────────────────────────────────────
// Phase 3.0 — Enterprise Expansion Layer
// ─────────────────────────────────────────────

// ─── NEW ENUMS ────────────────────────────────

enum PlanType {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  PAUSED
  INCOMPLETE
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum OrgMemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum UsageEventType {
  CHAT_MESSAGE
  QUIZ_GENERATE
  FLASHCARD_GENERATE
  DOCUMENT_EMBED
  DOCUMENT_PROCESS
  API_REQUEST
  STORAGE_UPLOAD
  TUTOR_INSIGHT
  KNOWLEDGE_GRAPH
}

// ─── BILLING DOMAIN ───────────────────────────

/// Canonical plan definitions — owned by platform admins
model Plan {
  id          String   @id @default(uuid())
  name        String // "Free", "Pro", "Team", "Enterprise"
  type        PlanType @unique
  description String?
  isActive    Boolean  @default(true)

  // Stripe price & limits requested overrides
  stripePriceId String? @unique
  limits        Json?

  // Stripe
  stripePriceIdMonthly String?
  stripePriceIdYearly  String?

  // Hard limits (null = unlimited)
  maxUsers          Int? // max seats per org
  maxDocuments      Int? // max docs per org
  maxStorageGb      Float? // max S3 storage
  maxChatsPerDay    Int? // daily chat quota
  maxApiCallsPerDay Int? // daily API call quota
  maxTokensPerMonth Int? // monthly LLM token budget

  // Pricing (USD cents)
  priceMonthlyUsdCents Int @default(0)
  priceYearlyUsdCents  Int @default(0)

  // Cost per unit (for usage-based billing, USD micro-cents)
  costPerTokenMicro     Int @default(0) // cost per 1000 tokens
  costPerDocumentCents  Int @default(0)
  costPerApiCallMicro   Int @default(0)
  costPerGbStorageCents Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  organizations Organization[]

  @@map("plans")
}

/// Billing tenant — represents a company/workspace (maps 1:1 to Stripe Customer)
model Organization {
  id              String  @id @default(uuid())
  name            String
  slug            String  @unique // URL-safe identifier
  logoUrl         String?
  domain          String? // e.g. "acme.com" for SSO domain matching
  isActive        Boolean @default(true)
  isSuspended     Boolean @default(false)
  suspendedReason String?

  // Stripe
  stripeCustomerId String? @unique

  // Billing contact
  billingEmail String?
  billingName  String?
  taxId        String?

  // Usage aggregates (denormalized for fast reads)
  storageUsedBytes BigInt @default(0)

  // Outbound Webhooks
  webhookUrl    String?
  webhookSecret String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  members           OrgMember[]
  orgInvites        OrgInvite[]
  documents         Document[]
  conversations     Conversation[]
  quizzes           Quiz[]
  knowledgeGraph    KnowledgeGraph?
  usageRecords      UsageRecord[]
  invitations       Invitation[]
  subscription      Subscription?
  invoices          Invoice[]
  apiKeys           ApiKey[]
  featureFlags      TenantFeatureOverride[]
  usageEvents       UsageEvent[]
  auditLogs         AuditLog[]
  ssoConfigurations SsoConfiguration[]
  domains           Domain[]
  securityEvents    SecurityEvent[]
  pluginInstalls    PluginInstall[]
  pluginUsageLogs   PluginUsageLog[]
  autonomousActions AutonomousAction[]
  aiGeneratedTools  AiGeneratedTool[]
  learningMetrics   LearningMetric[]
  aiTasks           AiTask[]
  aiSchedules       AiSchedule[]
  userProgress      UserProgress[]

  @@map("organizations")
}

model Subscription {
  id             String             @id @default(uuid())
  organizationId String             @unique
  planId         String
  status         SubscriptionStatus @default(TRIALING)
  cycle          BillingCycle       @default(MONTHLY)

  // Stripe
  stripeSubscriptionId String? @unique
  stripeItemId         String? // for quantity/usage-based items

  // Dates
  trialStartAt       DateTime?
  trialEndAt         DateTime?
  currentPeriodStart DateTime  @default(now())
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?

  // Usage-based billing snapshot for current period
  currentPeriodChatsUsed    Int @default(0)
  currentPeriodTokensUsed   Int @default(0)
  currentPeriodApiCallsUsed Int @default(0)

  userId String?
  user   User?   @relation("UserSubscriptions", fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([stripeSubscriptionId])
  @@map("subscriptions")
}

model Invoice {
  id                 String        @id @default(uuid())
  organizationId     String
  stripeInvoiceId    String?       @unique
  status             InvoiceStatus @default(DRAFT)
  amountDueUsdCents  Int           @default(0)
  amountPaidUsdCents Int           @default(0)
  currency           String        @default("usd")
  invoicePdfUrl      String?
  hostedInvoiceUrl   String?
  periodStart        DateTime?
  periodEnd          DateTime?
  dueDate            DateTime?
  paidAt             DateTime?
  userId             String?
  user               User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@map("invoices")
}

/// Idempotent Stripe event log — prevents double-processing webhooks
model StripeEvent {
  id          String   @id // Stripe event ID (evt_xxx) as PK for idempotency
  type        String // e.g. "customer.subscription.updated"
  processedAt DateTime @default(now())
  payload     Json // raw Stripe event object

  @@map("stripe_events")
}

model GamificationIdempotency {
  key         String   @id
  userId      String
  orgId       String?
  action      String
  xpAwarded   Int
  createdAt   DateTime @default(now())

  @@map("gamification_idempotency_log")
}

model UsageRecord {
  id           String   @id @default(uuid())
  userId       String
  date         DateTime @default(now())
  tokensUsed   Int      @default(0)
  uploadsCount Int      @default(0)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId        String?
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("usage_records")
}

// ─── USAGE DOMAIN ─────────────────────────────

/// Raw usage events — high write volume, partitioned by tenantId + date
model UsageEvent {
  id             String         @id @default(uuid())
  organizationId String
  userId         String? // null for API key calls
  apiKeyId       String?
  type           UsageEventType
  tokensIn       Int            @default(0)
  tokensOut      Int            @default(0)
  costUsdMicro   Int            @default(0) // cost in USD micro-cents (1/1000 cent)
  metadata       Json? // model name, document id, etc.
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, type, createdAt])
  @@index([organizationId, userId, createdAt])
  @@map("usage_events")
}

/// Pre-aggregated usage rollups — computed by a background job every hour
model UsageAggregate {
  id             String  @id @default(uuid())
  organizationId String
  userId         String?
  period         String // "2024-06-24-14" (yyyy-mm-dd-HH, hourly) or "2024-06-24" (daily)
  granularity    String // "hourly" | "daily" | "monthly"

  chatMessages         Int    @default(0)
  quizGenerations      Int    @default(0)
  flashcardGenerations Int    @default(0)
  documentProcesses    Int    @default(0)
  apiRequests          Int    @default(0)
  tokensIn             Int    @default(0)
  tokensOut            Int    @default(0)
  totalCostUsdMicro    Int    @default(0)
  storageBytes         BigInt @default(0)

  computedAt DateTime @default(now())

  @@unique([organizationId, userId, period, granularity])
  @@index([organizationId, period])
  @@map("usage_aggregates")
}

// ─── TEAMS DOMAIN ─────────────────────────────

model OrgMember {
  id       String        @id @default(uuid())
  orgId    String
  userId   String
  role     OrgMemberRole @default(MEMBER)
  joinedAt DateTime      @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@map("org_members")
}

model OrgInvite {
  id        String    @id @default(uuid())
  orgId     String
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("org_invites")
}

model KnowledgeGraph {
  id        String   @id @default(uuid())
  orgId     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("knowledge_graphs")
}

model Invitation {
  id             String           @id @default(uuid())
  organizationId String
  email          String // invitee email
  role           OrgMemberRole    @default(MEMBER)
  token          String           @unique // signed invite token
  status         InvitationStatus @default(PENDING)
  invitedById    String // userId of inviter
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([email, status])
  @@index([token])
  @@map("invitations")
}

// ─── API KEYS DOMAIN ──────────────────────────

/// API keys stored as prefix + SHA-256 hash (never plaintext)
model ApiKey {
  id             String       @id @default(uuid())
  organizationId String
  name           String // human-readable label
  keyPrefix      String // first 8 chars: "sk_live_" (shown in UI)
  keyHash        String       @unique // SHA-256 of full key
  status         ApiKeyStatus @default(ACTIVE)

  // Permissions (which API products this key can access)
  permissions Json // string[]: ["chat", "quiz", "flashcard", "analytics"]

  // Quota overrides (null = use org plan limits)
  dailyCallLimit    Int?
  monthlyTokenLimit Int?

  // Usage tracking (denormalized for fast checks)
  totalCallCount Int       @default(0)
  lastUsedAt     DateTime?

  expiresAt   DateTime?
  revokedAt   DateTime?
  createdById String? // userId
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  usageLogs    ApiUsageLog[]

  @@index([organizationId, status])
  @@map("api_keys")
}

model ApiUsageLog {
  id         String   @id @default(uuid())
  apiKeyId   String
  endpoint   String
  method     String
  statusCode Int
  tokensIn   Int      @default(0)
  tokensOut  Int      @default(0)
  latencyMs  Int      @default(0)
  createdAt  DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, createdAt])
  @@map("api_usage_logs")
}

// ─── FEATURE FLAGS DOMAIN ─────────────────────

/// Global feature catalog
model FeatureFlag {
  id           String  @id @default(uuid())
  key          String  @unique // e.g. "knowledge_graph", "tutor_agent"
  description  String?
  defaultValue Boolean @default(false) // global default
  enabledPlans Json // PlanType[]: which plans get this by default

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  overrides TenantFeatureOverride[]

  @@map("feature_flags")
}

/// Per-organization flag overrides (e.g. enterprise custom enablement)
model TenantFeatureOverride {
  id             String  @id @default(uuid())
  organizationId String
  featureFlagId  String
  enabled        Boolean

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  featureFlag  FeatureFlag  @relation(fields: [featureFlagId], references: [id], onDelete: Cascade)

  @@unique([organizationId, featureFlagId])
  @@map("tenant_feature_overrides")
}

// ─── ADMIN / AUDIT DOMAIN ─────────────────────

/// Immutable audit log for compliance
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  actorId        String? // userId or "system"
  actorType      String // "user" | "admin" | "system" | "api_key"
  action         String // "subscription.upgraded", "user.invited", etc.
  resourceType   String? // "subscription", "user", "api_key", etc.
  resourceId     String?
  correlationId  String? // Tracing ID for request lifecycle
  metadata       Json? // before/after state diff
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model IdentityProvider {
  id             String   @id @default(uuid())
  userId         String
  provider       String // "GOOGLE" | "AZURE" | "OKTA" | "SAML"
  providerUserId String // Unique ID from identity provider
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("identity_providers")
}

model SsoConfiguration {
  id             String   @id @default(uuid())
  organizationId String
  providerType   String // "SAML" | "OIDC"
  entryPoint     String // IdP Sign-on URL
  issuer         String // Entity ID / Issuer URI
  cert           String?  @db.Text // Public X.509 certificate for SAML signature validation
  clientId       String? // OIDC client ID
  clientSecret   String? // OIDC client secret
  wellKnownUrl   String? // OIDC metadata URL
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("sso_configurations")
}

model Domain {
  id             String   @id @default(uuid())
  organizationId String
  domainName     String   @unique // e.g. "acme.com"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("domains")
}

model SecurityEvent {
  id             String   @id @default(uuid())
  userId         String?
  organizationId String?
  eventType      String // "login_failed" | "geo_velocity_anomaly" | "brute_force" | "mfa_bypass"
  severity       String // "INFO" | "WARNING" | "CRITICAL"
  ipAddress      String?
  userAgent      String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@map("security_events")
}

model Plugin {
  id                    String   @id @default(uuid())
  key                   String   @unique // e.g. "wolfram_alpha"
  name                  String
  version               String
  description           String
  permissions           Json // string[]: ["read_documents", "external_api_call"]
  inputSchema           Json // JSON Schema defining inputs
  outputSchema          Json // JSON Schema defining outputs
  endpointUrl           String? // URL for remote HTTP tool calls
  scriptCode            String?  @db.Text // Sandboxed JS code (optional)
  authType              String   @default("NONE") // "NONE" | "API_KEY" | "OAUTH"
  priceMonthlyCents     Int      @default(0)
  costPerExecutionCents Int      @default(0)
  isActive              Boolean  @default(true)
  authorId              String // User ID of developer
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  installs  PluginInstall[]
  usageLogs PluginUsageLog[]
  ratings   PluginRating[]

  @@map("plugins")
}

model PluginInstall {
  id             String   @id @default(uuid())
  organizationId String
  pluginId       String
  installedById  String
  config         Json? // Encrypted API keys or credentials needed for the plugin
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin       Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([organizationId, pluginId])
  @@map("plugin_installs")
}

model PluginUsageLog {
  id             String   @id @default(uuid())
  organizationId String
  pluginId       String
  userId         String?
  conversationId String?
  latencyMs      Int
  statusCode     Int
  costCents      Float    @default(0)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plugin       Plugin       @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@index([organizationId, pluginId])
  @@map("plugin_usage_logs")
}

model PluginRating {
  id        String   @id @default(uuid())
  pluginId  String
  userId    String
  rating    Int // 1 to 5
  review    String?  @db.Text
  createdAt DateTime @default(now())

  plugin Plugin @relation(fields: [pluginId], references: [id], onDelete: Cascade)

  @@unique([pluginId, userId])
  @@map("plugin_ratings")
}

enum AutonomousActionType {
  PROMPT_UPDATE
  PLUGIN_CREATE
  OPTIMIZATION
}

enum AutonomousActionStatus {
  PENDING_VALIDATION
  PENDING_APPROVAL
  APPROVED
  REJECTED
  DEPLOYED
  FAILED
  ROLLED_BACK
}

model AutonomousAction {
  id              String                 @id @default(uuid())
  organizationId  String
  actionType      AutonomousActionType
  status          AutonomousActionStatus @default(PENDING_VALIDATION)
  triggerReason   String                 @db.Text
  proposalDetails Json // Proposed prompt, plugin spec, or param tuning
  validationLogs  String?                @db.Text
  feedbackMsg     String?                @db.Text
  approvedById    String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@map("autonomous_actions")
}

model AiGeneratedTool {
  id             String                 @id @default(uuid())
  organizationId String
  name           String
  key            String                 @unique
  description    String
  inputSchema    Json
  outputSchema   Json
  scriptCode     String                 @db.Text
  testSuiteData  Json // Input/output pairs used for sandbox validation
  status         AutonomousActionStatus @default(PENDING_VALIDATION)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ai_generated_tools")
}

model LearningMetric {
  id             String   @id @default(uuid())
  organizationId String
  metricName     String
  value          Float
  dimensions     Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, metricName, createdAt])
  @@map("learning_metrics")
}

model PromptTemplateVersion {
  id            String   @id @default(uuid())
  mode          String // "study" | "quiz" | "flashcard"
  version       Int
  systemPrompt  String   @db.Text
  isActive      Boolean  @default(false)
  accuracyScore Float?
  tokenCount    Int?
  createdById   String?
  createdAt     DateTime @default(now())

  @@unique([mode, version])
  @@map("prompt_template_versions")
}

enum AiTaskStatus {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model AiTask {
  id         String       @id @default(uuid())
  tenantId   String
  type       String // "CHAT", "EMBEDDING", "SUMMARIZATION", "REASONING", "BATCH"
  status     AiTaskStatus @default(QUEUED)
  costCents  Float        @default(0)
  latencyMs  Int          @default(0)
  inputData  Json
  outputData Json?
  errorLogs  String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@map("ai_tasks")
}

model AiComputeLog {
  id          String   @id @default(uuid())
  executionId String
  model       String
  tokensIn    Int      @default(0)
  tokensOut   Int      @default(0)
  costCents   Float    @default(0)
  latencyMs   Int      @default(0)
  createdAt   DateTime @default(now())

  @@index([executionId])
  @@map("ai_compute_logs")
}

model AiSchedule {
  id             String   @id @default(uuid())
  tenantId       String
  cronExpression String
  taskType       String // "graph_update", "study_plan", "memory_summarization"
  params         Json?
  nextRun        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("ai_schedules")
}

enum BadgeTriggerType {
  ACTION
  MILESTONE
  STREAK
}

model UserProgress {
  id        String   @id @default(uuid())
  userId    String
  orgId     String   @default("personal")
  totalXP   Int      @default(0)
  level     Int      @default(1)
  weeklyXP  Int      @default(0)
  monthlyXP Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("user_progress")
}

model Streak {
  id                 String    @id @default(uuid())
  userId             String    @unique
  currentStreak      Int       @default(0)
  longestStreak      Int       @default(0)
  lastActivityDate   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Badge {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String
  icon         String
  triggerType  BadgeTriggerType
  triggerValue Int
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  userBadges   UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

enum Platform {
  IOS
  ANDROID
}

model DeviceToken {
  id               String   @id @default(uuid())
  userId           String
  deviceId         String   @unique
  platform         Platform
  fcmToken         String?
  refreshTokenHash String?
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("device_tokens")
}

model NotificationPreference {
  id        String   @id @default(uuid())
  userId    String
  type      String   // BADGE_AWARD | STREAK_REMINDER | DOC_STATUS | QUIZ_COMPLETE | ORG_INVITE
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("notification_preferences")
}

